# ---- Database (Neon free tier in prod; local Postgres or Neon in dev) ----
# Pooled connection used by the app at runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct (non-pooled) connection used by Prisma migrate
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---- Redis (Upstash free tier; for BullMQ jobs + caching) ----
REDIS_URL="redis://localhost:6379"

# ---- Auth ----
JWT_SECRET="dev-only-change-me"
JWT_EXPIRES_IN="7d"

# ---- Payments (Stripe test mode) ----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ---- API ----
API_PORT="4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ---- Multi-tenant public sites ----
# Public franchise sites resolve tenant by hostname: {slug}.PLATFORM_ROOT_DOMAIN or a custom domain.
PLATFORM_ROOT_DOMAIN="localhost:3001"

# ---- Messaging (left blank in dev -> console adapter is used) ----
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""
SENDGRID_API_KEY=""
