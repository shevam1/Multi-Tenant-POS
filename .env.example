# ─────────────────────────────────────────────────────────────────────────────
# OmniPOS environment configuration
# Copy to .env and fill in the values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# IMPORTANT: DATABASE_URL must be the *app* role (omnipos_app) — NOT the owner.
# The app role has NOBYPASSRLS so Postgres RLS enforces tenant isolation.
# The direct URL (owner) is used ONLY by Prisma migrate/push/seed.
DATABASE_URL="postgresql://omnipos_app:APP_PASSWORD@HOST-pooler.neon.tech/neondb?sslmode=require&connect_timeout=30"
DIRECT_URL="postgresql://neondb_owner:OWNER_PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# ── Redis (Upstash free tier) ─────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# ── Payments (Stripe test mode) ───────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT="4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ── Multi-tenant public sites ─────────────────────────────────────────────────
# Franchise booking sites resolve tenant by hostname: {slug}.PLATFORM_ROOT_DOMAIN
PLATFORM_ROOT_DOMAIN="localhost:3001"

# ── Messaging (blank = console adapter; fill in for live SMS/email) ───────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""
SENDGRID_API_KEY=""
