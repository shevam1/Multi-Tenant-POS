{
  "name": "omnipos",
  "version": "0.1.0",
  "private": true,
  "description": "OmniPOS — multi-tenant commerce platform. One core, many domain modules (pet grooming, restaurant, ...).",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @omnipos/db generate",
    "db:migrate": "pnpm --filter @omnipos/db migrate",
    "db:push": "pnpm --filter @omnipos/db push",
    "db:seed": "pnpm --filter @omnipos/db seed",
    "db:studio": "pnpm --filter @omnipos/db studio"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "prettier": "^3.4.0"
  }
}
